PORT=3000
NODE_ENV=production
TRUST_PROXY=1

TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

JWT_SECRET=
ASSET_SESSION_SECRET=

ADMIN_EMAIL=
ADMIN_PASSWORD=

# Optional: comma-separated extra origins for custom domains
CORS_ORIGINS=
APP_URL=

# Optional captcha
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
RECAPTCHA_ENFORCE_LOCAL=1

# Browser write guard
BROWSER_WRITE_GUARD_ENABLED=1
BROWSER_WRITE_GUARD_REQUIRE_HEADER=1

# Anti-spam for post creation
SPAM_POST_COOLDOWN_MS=30000
SPAM_POST_WINDOW_MS=600000
SPAM_POST_MAX_PER_WINDOW=6
SPAM_POST_DUPLICATE_WINDOW_MS=86400000

# Optional Link4m free-spin integration
LINK4M_API_KEY=
LINK4M_API_ENDPOINT=https://link4m.co/api-shorten/v2
